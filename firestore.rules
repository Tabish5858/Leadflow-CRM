rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper: check if user owns the document
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Helper: check if user is a workspace member
    function isWorkspaceMember(workspaceId) {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/workspaces/$(workspaceId)) &&
        get(/databases/$(database)/documents/workspaces/$(workspaceId)).data.memberIds
          .hasAny([request.auth.uid]);
    }

    // Helper: check user role in workspace
    function hasRole(workspaceId, role) {
      return isWorkspaceMember(workspaceId) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == role;
    }

    // Users collection — users can only read/write their own doc
    match /users/{userId} {
      allow read: if isOwner(userId);
      allow write: if isOwner(userId);
    }

    // Workspaces — members can read, owners/admins can update, owners can delete
    match /workspaces/{workspaceId} {
      allow read: if isWorkspaceMember(workspaceId);
      allow create: if isAuthenticated();
      allow update: if hasRole(workspaceId, 'owner') || hasRole(workspaceId, 'admin');
      allow delete: if hasRole(workspaceId, 'owner');
    }

    // Leads — workspace members can read/create/update, admins/owners can delete
    match /leads/{leadId} {
      allow read: if isWorkspaceMember(resource.data.workspaceId);
      allow create: if isWorkspaceMember(request.resource.data.workspaceId);
      allow update: if isWorkspaceMember(resource.data.workspaceId);
      allow delete: if hasRole(resource.data.workspaceId, 'admin') ||
        hasRole(resource.data.workspaceId, 'owner');
    }

    // Activities — workspace members can read/create, admins/owners can update/delete
    match /activities/{activityId} {
      allow read: if isWorkspaceMember(resource.data.workspaceId);
      allow create: if isWorkspaceMember(request.resource.data.workspaceId);
      allow update, delete: if hasRole(resource.data.workspaceId, 'admin') ||
        hasRole(resource.data.workspaceId, 'owner');
    }

    // Tasks — workspace members can read/create/update, admins/owners can delete
    match /tasks/{taskId} {
      allow read: if isWorkspaceMember(resource.data.workspaceId);
      allow create: if isWorkspaceMember(request.resource.data.workspaceId);
      allow update: if isWorkspaceMember(resource.data.workspaceId);
      allow delete: if hasRole(resource.data.workspaceId, 'admin') ||
        hasRole(resource.data.workspaceId, 'owner');
    }

    // Time entries — workspace members can read/create, owners can delete
    match /timeEntries/{entryId} {
      allow read: if isWorkspaceMember(resource.data.workspaceId);
      allow create: if isWorkspaceMember(request.resource.data.workspaceId);
      allow update: if isWorkspaceMember(resource.data.workspaceId) &&
        resource.data.userId == request.auth.uid;
      allow delete: if hasRole(resource.data.workspaceId, 'admin') ||
        hasRole(resource.data.workspaceId, 'owner');
    }

    // Automations — workspace members can read, admins/owners can manage
    match /automations/{automationId} {
      allow read: if isWorkspaceMember(resource.data.workspaceId);
      allow create, update, delete: if hasRole(resource.data.workspaceId, 'admin') ||
        hasRole(resource.data.workspaceId, 'owner');
    }

    // Notifications — users can only read/write their own
    match /notifications/{notificationId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if true; // Created by Cloud Functions
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }
  }
}
