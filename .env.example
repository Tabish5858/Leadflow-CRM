# Firebase (Client)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Firebase (Server - Admin SDK)
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
FIREBASE_ADMIN_PRIVATE_KEY=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=LeadFlow
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
NODE_ENV=development

# Workspace creation restriction (optional — comma-separated email list)
# Uses server-only env var (NOT NEXT_PUBLIC_) to avoid leaking emails to client.
# If empty, no one can create workspaces via UI.
ALLOWED_WORKSPACE_CREATORS=

# Email (Resend — primary, recommended)
# Sign up at https://resend.com, verify your domain, and paste the API key.
# Free tier: 100 emails/day, 3,000/month.
RESEND_API_KEY=
FROM_EMAIL=your-verified-sender@yourdomain.com
FROM_NAME=LeadFlow CRM

# Email (Brevo — optional fallback)
# Only needed if you prefer Brevo over Resend. Uncomment and set BREVO_API_KEY instead.
# BREVO_API_KEY=

# Cloudinary (Document Storage)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_URL=

# Google Calendar OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_Project_ID=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# Sentry (Error Monitoring)
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
